<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="LearnCSharpApp.Views.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:LearnCSharpApp.ViewModels"
    x:DataType="viewModels:HomeViewModel"
    Title="Главная">

    <ScrollView BackgroundColor="{AppThemeBinding Light=#F6F7FB, Dark=#111827}">
        <VerticalStackLayout Padding="24,32" Spacing="24">
            <Border Margin="4" StrokeThickness="0" StrokeShape="RoundRectangle 32" Padding="24">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#2563EB" Offset="0" />
                        <GradientStop Color="#7C3AED" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <VerticalStackLayout Spacing="18">
                    <Label Text="LearnCSharpApp" TextColor="White" FontSize="30" FontAttributes="Bold" />
                    <Label
                        Text="Изучайте C# по коротким урокам, закрепляйте материал тестами внутри уроков и отслеживайте прогресс."
                        TextColor="#DBEAFE"
                        FontSize="15"
                        LineBreakMode="WordWrap" />
                    <ProgressBar Progress="{Binding ProgressValue}" ProgressColor="White" BackgroundColor="#60A5FA" HeightRequest="8" />
                    <Label TextColor="White" FontSize="18" FontAttributes="Bold">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="{Binding CompletedLessons}" />
                                <Span Text=" из " />
                                <Span Text="{Binding TotalLessons}" />
                                <Span Text=" уроков завершено" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </VerticalStackLayout>
            </Border>

            <Border Padding="18" Margin="4" StrokeThickness="0" StrokeShape="RoundRectangle 24" BackgroundColor="{AppThemeBinding Light=White, Dark=#1F2937}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenLessonsCommand}" />
                </Border.GestureRecognizers>

                <VerticalStackLayout Spacing="8">
                    <Label Text="Уроки" FontSize="18" FontAttributes="Bold" />
                    <Label Text="Откройте нужную тему, изучите теорию и запустите тест из выбранного урока." TextColor="{AppThemeBinding Light=#6B7280, Dark=#D1D5DB}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
