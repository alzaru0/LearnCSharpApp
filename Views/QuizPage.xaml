<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="LearnCSharpApp.Views.QuizPage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:LearnCSharpApp.Models"
    xmlns:viewModels="clr-namespace:LearnCSharpApp.ViewModels"
    x:DataType="viewModels:QuizViewModel"
    Title="Тест">

    <Grid BackgroundColor="{AppThemeBinding Light=#F6F7FB, Dark=#111827}">
        <CollectionView
            ItemsSource="{Binding Questions}"
            SelectionMode="None"
            Margin="18,24"
            VerticalScrollBarVisibility="Never">
            <CollectionView.Header>
                <VerticalStackLayout Spacing="16" Margin="0,0,0,18">
                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="Тестирование"
                            FontSize="30"
                            FontAttributes="Bold"
                            TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" />
                        <Label
                            Text="Ответьте на вопросы по выбранному уроку и получите итоговый балл."
                            FontSize="15"
                            TextColor="{AppThemeBinding Light=#6B7280, Dark=#D1D5DB}" />
                        <Label
                            Text="{Binding SelectedLessonTitle}"
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="#2563EB"
                            IsVisible="{Binding HasSelectedLesson}" />
                    </VerticalStackLayout>

                    <Border Padding="20" Margin="4" StrokeThickness="0" StrokeShape="RoundRectangle 26" BackgroundColor="{AppThemeBinding Light=White, Dark=#1F2937}">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding ResultText}" FontSize="18" FontAttributes="Bold" />
                                <Label FontSize="13" TextColor="{AppThemeBinding Light=#6B7280, Dark=#D1D5DB}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Вопросов в тесте: " />
                                            <Span Text="{Binding TotalQuestions}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </VerticalStackLayout>

                            <Border
                                Grid.Column="1"
                                Padding="14,8"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18"
                                BackgroundColor="#DBEAFE"
                                IsVisible="{Binding HasResult}">
                                <Label
                                    Text="{Binding Score}"
                                    TextColor="#1D4ED8"
                                    FontSize="20"
                                    FontAttributes="Bold" />
                            </Border>
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </CollectionView.Header>

            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="0,48" Spacing="10" HorizontalOptions="Center">
                    <Label
                        Text="{Binding EmptyMessage}"
                        FontSize="18"
                        FontAttributes="Bold"
                        HorizontalTextAlignment="Center"
                        TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:QuizQuestion">
                    <Border
                        Margin="4,4,4,16"
                        Padding="18"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 26"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1F2937}">
                        <VerticalStackLayout Spacing="14">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Border WidthRequest="38" HeightRequest="38" StrokeThickness="0" StrokeShape="RoundRectangle 14" BackgroundColor="#EEF2FF">
                                    <Label Text="{Binding DisplayNumber}" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#4F46E5" FontAttributes="Bold" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="{Binding LessonTitle}" FontSize="12" TextColor="#2563EB" FontAttributes="Bold" />
                                    <Label Text="{Binding QuestionText}" FontSize="16" FontAttributes="Bold" LineBreakMode="WordWrap" />
                                </VerticalStackLayout>
                            </Grid>

                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Options}" Spacing="8">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:QuizAnswerOption">
                                        <Border
                                            Padding="14"
                                            Stroke="#E5E7EB"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 18"
                                            BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#111827}">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.SelectAnswerCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>

                                            <Label Text="{Binding Text}" FontSize="14" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" />

                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BackgroundColor" Value="#DBEAFE" />
                                                    <Setter Property="Stroke" Value="#2563EB" />
                                                </DataTrigger>
                                            </Border.Triggers>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.Footer>
                <VerticalStackLayout Spacing="10" Margin="0,8,0,24">
                    <Button
                        Text="Завершить тест"
                        Command="{Binding SubmitQuizCommand}"
                        IsVisible="{Binding CanSubmitQuiz}"
                        CornerRadius="18"
                        HeightRequest="52"
                        MinimumWidthRequest="170"
                        HorizontalOptions="Fill" />

                    <Button
                        Text="Сбросить ответы"
                        Command="{Binding ResetQuizCommand}"
                        IsVisible="{Binding CanShowResultActions}"
                        BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                        TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"
                        CornerRadius="18"
                        HeightRequest="52"
                        MinimumWidthRequest="170"
                        HorizontalOptions="Fill" />

                    <Button
                        Text="Вернуться к уроку"
                        Command="{Binding ReturnToLessonCommand}"
                        IsVisible="{Binding CanShowResultActions}"
                        BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                        TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"
                        CornerRadius="18"
                        HeightRequest="52"
                        MinimumWidthRequest="170"
                        HorizontalOptions="Fill" />
                </VerticalStackLayout>
            </CollectionView.Footer>
        </CollectionView>

        <Grid
            Padding="24"
            BackgroundColor="#99000000"
            IsVisible="{Binding IsResultPopupVisible}"
            ZIndex="10">
            <Border
                Padding="24"
                MaximumWidthRequest="420"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 32"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1F2937}">
                <Border.Shadow>
                    <Shadow
                        Brush="#111827"
                        Offset="0,14"
                        Radius="28"
                        Opacity="0.24" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="18">
                    <Grid>
                        <VerticalStackLayout Spacing="4">
                            <Label
                                Text="Результат теста"
                                FontSize="24"
                                FontAttributes="Bold"
                                TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" />
                            <Label
                                Text="{Binding SelectedLessonTitle}"
                                FontSize="14"
                                TextColor="{AppThemeBinding Light=#6B7280, Dark=#D1D5DB}" />
                        </VerticalStackLayout>
                    </Grid>

                    <Border
                        Padding="20"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 26"
                        BackgroundColor="{AppThemeBinding Light=#EFF6FF, Dark=#111827}">
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                <VerticalStackLayout Spacing="2">
                                    <Label
                                        Text="{Binding ResultText}"
                                        FontSize="18"
                                        FontAttributes="Bold"
                                        TextColor="{AppThemeBinding Light=#1D4ED8, Dark=#93C5FD}" />
                                    <Label
                                        Text="{Binding ResultFeedbackText}"
                                        FontSize="13"
                                        TextColor="{AppThemeBinding Light=#6B7280, Dark=#D1D5DB}" />
                                </VerticalStackLayout>

                                <Label
                                    Grid.Column="1"
                                    Text="{Binding ResultPercentText}"
                                    FontSize="28"
                                    FontAttributes="Bold"
                                    VerticalOptions="Center"
                                    TextColor="{AppThemeBinding Light=#2563EB, Dark=#60A5FA}" />
                            </Grid>

                            <ProgressBar
                                Progress="{Binding ResultProgress}"
                                HeightRequest="8"
                                ProgressColor="#2563EB"
                                BackgroundColor="{AppThemeBinding Light=#DBEAFE, Dark=#374151}" />
                        </VerticalStackLayout>
                    </Border>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button
                            Text="Повторить"
                            Command="{Binding ResetQuizCommand}"
                            BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                            TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"
                            CornerRadius="18"
                            HeightRequest="50" />

                        <Button
                            Grid.Column="1"
                            Text="Готово"
                            Command="{Binding CloseResultPopupCommand}"
                            CornerRadius="18"
                            HeightRequest="50" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
