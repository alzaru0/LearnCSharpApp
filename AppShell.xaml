<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="LearnCSharpApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="LearnCSharpApp"
    Shell.NavBarHasShadow="False"
    Shell.BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#111827}"
    Shell.ForegroundColor="#2563EB"
    Shell.TitleColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"
    Shell.TabBarBackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#111827}"
    Shell.TabBarForegroundColor="#2563EB"
    Shell.TabBarTitleColor="#2563EB"
    Shell.TabBarUnselectedColor="{AppThemeBinding Light=#9CA3AF, Dark=#6B7280}">

</Shell>
